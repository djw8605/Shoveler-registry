# ---------------------------------------------------------------------------
# Shoveler Auth Portal configuration. Copy to `.env` and fill in.
# ---------------------------------------------------------------------------

# --- The portal's OWN CILogon OIDC client (for logging humans in) ---
# Register a CONFIDENTIAL client at https://cilogon.org/oauth2/register with
# redirect URI  <PORTAL_BASE_URL>/auth/callback  and scopes:
#   openid email profile org.cilogon.userinfo
# NOTE: these are DISTINCT from the shoveler client_id/secret this service issues.
CILOGON_CLIENT_ID=cilogon:/client_id/abc123
CILOGON_CLIENT_SECRET=change-me
CILOGON_DISCOVERY_URL=https://cilogon.org/.well-known/openid-configuration

# Public base URL of this portal (used to build the OIDC redirect URI).
PORTAL_BASE_URL=https://shoveler-auth.osg.example

# Secret used to sign session cookies. Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
SESSION_SECRET=change-me-to-a-long-random-string

# --- Storage ---
DB_PATH=./data/portal.db
SIGNING_KEY_DIR=./data/keys

# --- Claims for the JWTs this service issues (must match RabbitMQ config) ---
# iss claim; RabbitMQ's auth_oauth2.issuer must equal this exactly.
TOKEN_ISSUER=https://shoveler-auth.osg.example/
# aud claim; RabbitMQ's auth_oauth2.resource_server_id must equal this EXACTLY.
RESOURCE_SERVER_ID=my_rabbit_server
# Token lifetime in seconds (default 4 hours).
TOKEN_TTL_SECONDS=14400
# Custom scope claim RabbitMQ reads via auth_oauth2.additional_scopes_key.
SCOPE_CLAIM=extra_scope
SCOPE_VALUE=my_rabbit_server.write:*/xrd-shoveled

# --- Authorization (COmanage groups, via CILogon's isMemberOf claim) ---
# Site authorization is driven by the user's COmanage group memberships rather
# than a local allow-list. A group named "<COMANAGE_GROUP_PREFIX><site>" grants
# management of <site>; e.g. with the default prefix below, membership in the
# COmanage group "shoveler-nebraska" lets a user manage site "nebraska".
COMANAGE_GROUP_PREFIX=shoveler-
# Members of this COmanage group are registry-wide admins: they see ALL sites'
# credentials at /admin and may disable any client. Leave empty to disable the
# admin view entirely.
REGISTRY_ADMIN_GROUP=shoveler-admins

# --- Operational ---
# Disable credentials unused for this many days (idle-expiry job).
IDLE_DAYS=30
# Shown to users who aren't a member of any site group.
ADMIN_CONTACT=osg-help@opensciencegrid.org
# Per-client_id rate limit on /token: TOKEN_RATE_LIMIT requests per window seconds.
TOKEN_RATE_LIMIT=30
TOKEN_RATE_WINDOW=60
