# Python
__pycache__/
*.pyc
.venv/
*.egg-info/
.pytest_cache/

# Node (build-time only)
node_modules/

# Compiled CSS is a BUILD ARTIFACT (source: assets/app.css). Regenerated by
# `npm run build:css` and by the Docker build.
portal/static/css/app.css

# Secrets & local data — NEVER commit signing keys or the DB
.env
data/
*.db
*.db-wal
*.db-shm
site-admins.yaml

# Signing keys (defense in depth; keys live under data/ by default)
*.pem
manifest.json

# keep the static dir present even though app.css is ignored
!portal/static/css/.gitkeep
